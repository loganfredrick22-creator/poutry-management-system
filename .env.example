# FarmLink Configuration
# Copy this file to .env and modify as needed

# Secret key for session security (change this in production!)
FARMLINK_SECRET_KEY=dev-secret-change-me

# Database Configuration
# Options: "sqlite" (default) or "mysql"
FARMLINK_DB_TYPE=sqlite

# MySQL Configuration (only needed if FARMLINK_DB_TYPE=mysql)
FARMLINK_MYSQL_HOST=localhost
FARMLINK_MYSQL_PORT=3306
FARMLINK_MYSQL_USER=farmlink
FARMLINK_MYSQL_PASSWORD=your_mysql_password
FARMLINK_MYSQL_DATABASE=farmlink

# Access Control Settings
# Set to 'true' to enable editing for all authenticated users
# Set to 'false' to restrict editing to admin users only
FARMLINK_ENABLE_EDITING_FOR_ALL=false

# Alternative: Set edit mode
# Options: "admin_only" (restrict editing to admins only), "all_users" (allow all authenticated users to edit)
FARMLINK_EDIT_MODE=admin_only

# Examples for hosting on another computer:
# To allow all users to edit when hosted elsewhere:
# FARMLINK_EDIT_MODE=all_users
# or
# FARMLINK_ENABLE_EDITING_FOR_ALL=true

# MySQL Setup Example:
# FARMLINK_DB_TYPE=mysql
# FARMLINK_MYSQL_HOST=localhost
# FARMLINK_MYSQL_USER=farmlink
# FARMLINK_MYSQL_PASSWORD=secure_password
# FARMLINK_MYSQL_DATABASE=farmlink
